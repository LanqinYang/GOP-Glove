*.tmp

# Configuration files with sensitive data
config/secrets.yaml
.env.local 
models/trained/ 

# Keep only Arduino sketches (.ino) and the Arduino README tracked under tinyml_inference
arduino/tinyml_inference/**
!arduino/tinyml_inference/**/*.ino
!arduino/tinyml_inference/README.md 

# Also ignore any .txt artifacts under Arduino inference
arduino/tinyml_inference/**/*.txt

# Track Jupyter notebooks (*.ipynb) - no ignore rule needed; checkpoints are already ignored

# Do not track latency benchmark artifacts
src/test/latency_benchmark_test/A100/**
src/test/latency_benchmark_test/CPU/**
src/test/latency_benchmark_test/*.pdf
src/test/latency_benchmark_test/*.png
